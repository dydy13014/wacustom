# ===========================
# Wacustom - configuration d'exemple
# Copiez ce fichier en wacustom.env et renseignez vos valeurs.
# Ne committez jamais votre wacustom.env (il est déjà dans .gitignore).
# ===========================

# --- Obligatoire ---
# Clé de chiffrement des configs utilisateur (min. 32 caractères)
# Générer avec : openssl rand -hex 32
SECRET_KEY=

# Mot de passe d'accès à l'addon (page /configure et manifest)
ADDON_PASSWORD=

# Mot de passe du tableau de bord admin (laisser vide = admin désactivé)
ADMIN_PASSWORD=

# --- Base de données ---
DATABASE_TYPE=sqlite
DATABASE_PATH=/app/data/wastream.db

# --- Métadonnées ---
# Token API TMDB (peut aussi être renseigné via l'interface web)
TMDB_API_KEY=

# ===========================
# Sources - configurez au moins une source
# ===========================

# DDL françaises
WAWACITY_URL=
FREE_TELECHARGER_URL=
MOVIX_URL=
WEBSHARE_URL=

# Darki-API (optionnel)
DARKI_API_URL=
DARKI_API_KEY=

# Trackers Torznab (torrents via débrideur)
YGGREBORN_URL=https://www.yggreborn.org/api
YGGREBORN_API_KEY=
TR4KER_URL=https://tr4ker.net/api
TR4KER_API_KEY=
TORR9_URL=https://api.torr9.net/api/v1/torznab
TORR9_API_KEY=
C411_URL=https://c411.org/api
C411_API_KEY=

# Trackers UNIT3D (API JSON native)
GEMINI_URL=
GEMINI_API_KEY=
GENERATIONFREE_URL=
GENERATIONFREE_API_KEY=

# Zilean (index DMM public, pas de clé requise)
ZILEAN_URL=

# Nyaa (anime, flux RSS public, pas de clé requise)
NYAA_URL=https://nyaa.si

# ===========================
# Divers (optionnels)
# ===========================
# LOG_LEVEL=INFO
# PROXY_URL=
# PASTEBIN_SCRAPER_URLS=[]
